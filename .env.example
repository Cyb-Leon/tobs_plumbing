# Next.js Application Environment Variables

# Build and Deployment
NODE_ENV=production
NEXT_PUBLIC_SITE_URL=https://tobsplumbingandprojects.co.za

# Server Configuration
PORT=3000
HOSTNAME=localhost

# Analytics (Keep if using Vercel Analytics)
NEXT_PUBLIC_ANALYTICS_ENABLED=true

# Contact Form (if implementing email)
# NEXT_PUBLIC_CONTACT_EMAIL=info@tobsplumbing.co.za
# SMTP_HOST=mail.tobsplumbing.co.za
# SMTP_PORT=465
# SMTP_USER=your-email@tobsplumbing.co.za
# SMTP_PASS=your-password

# Social Media Links (for schema.org structured data)
# NEXT_PUBLIC_FACEBOOK_URL=https://facebook.com/tobsplumbing
# NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/tobsplumbing
# NEXT_PUBLIC_LINKEDIN_URL=https://linkedin.com/company/tobsplumbing

# Google Business & SEO
# NEXT_PUBLIC_GOOGLE_BUSINESS_ID=your-id
# NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=your-ga-id

# WhatsApp Integration
# NEXT_PUBLIC_WHATSAPP_NUMBER=+27XXXXXXXXX
